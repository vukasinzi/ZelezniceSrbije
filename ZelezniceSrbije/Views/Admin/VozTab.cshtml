@using System.Linq
@model ZelezniceSrbije.Models.ViewModels.VozoviVM
@{
    Layout = null;
    var tipovi = Model?.TipoviVoza ?? Enumerable.Empty<ZelezniceSrbije.Models.TipVoza>();
    var vozovi = Model?.Vozovi ?? Enumerable.Empty<ZelezniceSrbije.Models.Voz>();
}

<div class="card shadow-sm mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="card-header-label">Vozovi</span>
        </div>

        <form id="dodajVozForm" asp-controller="Admin" asp-action="DodajVoz" method="post" class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label sz-label">Naziv voza</label>
                <input type="text" name="naziv" class="form-control sz-input" placeholder="npr. Soko" required>
            </div>
            <div class="col-md-3">
                <label class="form-label sz-label">Serijski broj</label>
                <input type="text" name="serijski_broj" class="form-control sz-input" placeholder="npr. SOK-410-001" required>
            </div>
            <div class="col-md-3">
                <label class="form-label sz-label">Tip voza</label>
                <select id="vozTipSelect" name="tip_voza_id" class="form-select sz-input" required @(tipovi.Any() ? null : "disabled")>
                    <option value="">Izaberi tip...</option>
                    @foreach (var tip in tipovi)
                    {
                        <option value="@tip.Id">@tip.Naziv</option>
                    }
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label sz-label">Aktivan</label>
                <select name="aktivan" class="form-select sz-input">
                    <option value="true" selected>Da</option>
                    <option value="false">Ne</option>
                </select>
            </div>
            <div class="col-md-2 d-grid align-content-end">
                <button id="dodajVozBtn" type="submit" class="btn btn-sz-primary btn-match-input" @(tipovi.Any() ? null : "disabled")>Dodaj novi voz</button>
            </div>
        </form>

        <table class="table sz-table mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Naziv</th>
                    <th>Serijski broj</th>
                    <th>Tip voza</th>
                    <th>Aktivan</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="vozoviTableBody">
                @if (!vozovi.Any())
                {
                    <tr class="js-voz-empty">
                        <td class="text-muted" colspan="6">Nema vozova.</td>
                    </tr>
                }
                else
                {
                    foreach (var voz in vozovi)
                    {
                        var tipNaziv = tipovi.FirstOrDefault(t => t.Id == voz.Tip_voza_id)?.Naziv ?? "-";
                        <tr data-role="Voz" data-id="@voz.Id">
                            <td class="text-muted">@voz.Id</td>
                            <td>
                                <strong class="cell-view">@voz.Naziv</strong>
                                <input name="naziv" class="form-control form-control-sm cell-edit d-none" value="@voz.Naziv">
                            </td>
                            <td class="text-muted">
                                <span class="cell-view">@voz.Serijski_broj</span>
                                <input name="serijski_broj" class="form-control form-control-sm cell-edit d-none" value="@voz.Serijski_broj">
                            </td>
                            <td>
                                <span class="cell-view">@tipNaziv</span>
                                <select name="tip_voza_id" class="form-select form-select-sm cell-edit d-none">
                                    @foreach (var tip in tipovi)
                                    {
                                        if (tip.Id == voz.Tip_voza_id)
                                        {
                                            <option value="@tip.Id" selected>@tip.Naziv</option>
                                        }
                                        else
                                        {
                                            <option value="@tip.Id">@tip.Naziv</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td>
                                <span class="sz-badge @(voz.Aktivan ? "badge-aktivan" : "badge-neaktivan") cell-view">@(voz.Aktivan ? "Da" : "Ne")</span>
                                <select name="aktivan" class="form-select form-select-sm cell-edit d-none">
                                    @if (voz.Aktivan)
                                    {
                                        <option selected>Da</option>
                                        <option>Ne</option>
                                    }
                                    else
                                    {
                                        <option>Da</option>
                                        <option selected>Ne</option>
                                    }
                                </select>
                            </td>
                            <td class="cell-actions">
                                <button class="btn btn-sz-outline js-edit-toggle">Izmeni</button>
                                <button class="btn btn-sz-danger ms-2 js-delete-local">Ukloni</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="card-header-label">Tipovi Voza</span>
        </div>

        <form id="dodajTipVozaForm" asp-controller="Admin" asp-action="DodajTipVoza" method="post" class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label sz-label">Naziv tipa</label>
                <input type="text" name="naziv" class="form-control sz-input" placeholder="npr. InterCity" required>
            </div>
            <div class="col-md-6">
                <label class="form-label sz-label">Opis</label>
                <input type="text" name="opis" class="form-control sz-input" placeholder="npr. Brzi medjugradski vozovi" required>
            </div>
            <div class="col-md-2 d-grid align-content-end">
                <button type="submit" class="btn btn-sz-primary btn-match-input">Dodaj novi tip voza</button>
            </div>
        </form>

        <table class="table sz-table mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Naziv</th>
                    <th>Opis</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="tipoviTableBody">
                @if (!tipovi.Any())
                {
                    <tr class="js-tip-empty">
                        <td class="text-muted" colspan="4">Nema tipova vozova.</td>
                    </tr>
                }
                else
                {
                    foreach (var tip in tipovi)
                    {
                        <tr data-role="TipVoza" data-id="@tip.Id">
                            <td class="text-muted">@tip.Id</td>
                            <td>
                                <strong class="cell-view">@tip.Naziv</strong>
                                <input name="naziv" class="form-control form-control-sm cell-edit d-none" value="@tip.Naziv">
                            </td>
                            <td class="text-muted">
                                <span class="cell-view">@tip.Opis</span>
                                <input name="opis" class="form-control form-control-sm cell-edit d-none" value="@tip.Opis">
                            </td>
                            <td class="cell-actions">
                                <button class="btn btn-sz-outline js-edit-toggle">Izmeni</button>
                                <button class="btn btn-sz-danger ms-2 js-delete-local">Ukloni</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
