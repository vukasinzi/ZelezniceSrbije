<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel – Železnice Srbije</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --sz-red: #CC0000;
            --sz-blue: #003B8E;
        }

        body {
            font-family: 'Source Sans 3', sans-serif;
            background-color: #f4f6f9;
        }

        .sz-hero {
            background: var(--sz-blue);
            padding: 3rem 2rem 2.5rem;
            position: relative;
            overflow: hidden;
            margin-bottom: 2rem;
        }
        .sz-hero::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0; height: 6px;
            background: repeating-linear-gradient(
                90deg,
                var(--sz-red) 0px, var(--sz-red) 40px,
                #fff 40px, #fff 44px
            );
        }
        .sz-hero h1 {
            font-family: 'Oswald', sans-serif;
            font-size: 42px;
            color: white;
            font-weight: 600;
            margin: 0 0 8px;
        }
        .sz-hero h1 span { color: var(--sz-red); }
        .sz-hero p {
            color: rgba(255,255,255,0.8);
            font-size: 16px;
            margin: 0;
        }

        .nav-tabs .nav-link {
            font-family: 'Oswald', sans-serif;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6c757d;
            border: none;
            border-bottom: 3px solid transparent;
            padding: 10px 20px;
            background: none;
        }
        .nav-tabs .nav-link:hover { color: var(--sz-blue); border-bottom-color: var(--sz-blue); }
        .nav-tabs .nav-link.active {
            color: var(--sz-blue);
            border-bottom: 3px solid var(--sz-blue);
            font-weight: 600;
            background: none;
        }
        .nav-tabs { border-bottom: 2px solid #dee2e6; margin-bottom: 1.5rem; }

        .card { border: none; border-radius: 4px; }
        .card-header-label {
            font-family: 'Oswald', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-size: 13px;
            color: var(--sz-blue);
        }

        .sz-table thead th {
            font-family: 'Oswald', sans-serif;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #6c757d;
            border-bottom: 2px solid var(--sz-blue);
            padding: 10px 12px;
        }
        .sz-table tbody td {
            padding: 14px 12px;
            font-size: 0.95rem;
            vertical-align: middle;
            border-color: #f0f0f0;
        }
        .sz-table tbody tr:last-child td { border-bottom: none; }

        .sz-badge {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 3px 9px;
            border-radius: 2px;
        }
        .badge-admin     { background: #e6f0ff; color: var(--sz-blue); }
        .badge-kondukter { background: #ffe6e6; color: var(--sz-red);  }
        .badge-putnik    { background: #f0f0f0; color: #6c757d;        }
        .badge-aktivan   { background: #e8f5e9; color: #198754;        }
        .badge-neaktivan { background: #fdecea; color: #b71c1c;        }

        .btn-sz-primary {
            background: var(--sz-red); color: white; border: none;
            font-weight: 600; font-size: 0.875rem; border-radius: 2px; padding: 8px 18px;
        }
        .btn-sz-primary:hover { background: #aa0000; color: white; }

        .btn-sz-outline {
            border: 1px solid var(--sz-blue); color: var(--sz-blue);
            background: transparent; font-size: 0.8rem; font-weight: 600;
            border-radius: 2px; padding: 4px 12px;
        }
        .btn-sz-outline:hover { background: var(--sz-blue); color: white; }

        .sz-route {
            display: flex; flex-wrap: wrap; gap: 4px;
            list-style: none; padding: 0; margin: 0;
            font-size: 0.85rem; color: #444;
        }
        .sz-route li + li::before {
            content: '›'; color: var(--sz-red); margin-right: 4px; font-weight: 700;
        }
        .sz-route .vreme {
            font-size: 0.72rem; color: #aaa; display: block;
        }

        .field-label {
            font-size: 0.7rem; text-transform: uppercase;
            letter-spacing: 0.5px; color: #aaa; display: block; margin-bottom: 1px;
        }
    </style>
</head>
<body>


<div class="sz-hero">
    <div class="container">
        <h1>Admin <span>Panel</span></h1>
        <p>Centralni sistem za upravljanje infrastrukturom Železnica Srbije</p>
    </div>
</div>

<div class="container mb-5">

    <ul class="nav nav-tabs" id="adminTabs">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-korisnici">Korisnici</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-vozovi">Vozovi i Tipovi</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-linije">Linije i Stanice</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-rasporedi">Rasporedi</button>
        </li>
    </ul>

    <div class="tab-content">


        <div class="tab-pane fade show active" id="tab-korisnici">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Registar Korisnika</span>
