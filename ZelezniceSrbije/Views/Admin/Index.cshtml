                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Rasporedi Vožnje</span>
                        <button class="btn btn-sz-primary">+ Novi Raspored</button>
                    </div>
                    <table class="table sz-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Linija</th>
                                <th>Voz</th>
                                <th>Polazak</th>
                                <th>Dolazak</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">1</td>
                                <td><strong>Beograd – Novi Sad</strong></td>
                                <td>
                                    Soko
                                    <span class="field-label">SOK-410-001 · InterCity</span>
                                </td>
                                <td>
                                    <span class="cell-view">07:00, 01.04.2026.</span>
                                    <input class="form-control form-control-sm cell-edit d-none" value="07:00, 01.04.2026.">
                                </td>
                                <td>
                                    <span class="cell-view">07:45, 01.04.2026.</span>
                                    <input class="form-control form-control-sm cell-edit d-none" value="07:45, 01.04.2026.">
                                </td>
                                <td class="cell-actions">
                                    <button class="btn btn-sz-outline js-edit-toggle">Izmeni</button>
                                    <button class="btn btn-sz-danger ms-2">Ukloni</button>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">2</td>
                                <td><strong>Beograd – Novi Sad</strong></td>
                                <td>
                                    Regio Express
                                    <span class="field-label">RE-210-007 · Regio</span>
                                </td>
                                <td>
                                    <span class="cell-view">09:30, 01.04.2026.</span>
                                    <input class="form-control form-control-sm cell-edit d-none" value="09:30, 01.04.2026.">
                                </td>
                                <td>
                                    <span class="cell-view">10:15, 01.04.2026.</span>
                                    <input class="form-control form-control-sm cell-edit d-none" value="10:15, 01.04.2026.">
                                </td>
                                <td class="cell-actions">
                                    <button class="btn btn-sz-outline js-edit-toggle">Izmeni</button>
                                    <button class="btn btn-sz-danger ms-2">Ukloni</button>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">3</td>
                                <td><strong>Novi Sad – Subotica</strong></td>
                                <td>
                                    Regio Express
                                    <span class="field-label">RE-210-007 · Regio</span>
                                </td>
                                <td>
                                    <span class="cell-view">11:00, 01.04.2026.</span>
                                    <input class="form-control form-control-sm cell-edit d-none" value="11:00, 01.04.2026.">
                                </td>
                                <td>
                                    <span class="cell-view">12:05, 01.04.2026.</span>
                                    <input class="form-control form-control-sm cell-edit d-none" value="12:05, 01.04.2026.">
                                </td>
                                <td class="cell-actions">
                                    <button class="btn btn-sz-outline js-edit-toggle">Izmeni</button>
                                    <button class="btn btn-sz-danger ms-2">Ukloni</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const korisniciTabBtn = document.querySelector('[data-bs-target="#tab-korisnici"]');
            const korisniciTabContent = document.querySelector('#korisniciTabContent');
            if (korisniciTabBtn && korisniciTabContent) {
                let loaded = false;
                const loadLists = () => {
                    if (loaded) return;
                    loaded = true;
                    $('#korisniciTabContent').load('/Admin/UcitajKorisnike?ts=' + Date.now());
                };

                korisniciTabBtn.addEventListener('shown.bs.tab', loadLists);

                if (korisniciTabBtn.classList.contains('active')) {
                    loadLists();
                }
            }

            const vozTabBtn = document.querySelector('[data-bs-target="#tab-vozovi"]');
            const vozTabContent = document.querySelector('#vozTabContent');
            if (vozTabBtn && vozTabContent) {
                let vozLoaded = false;
                const loadVozTab = () => {
                    if (vozLoaded) return;
                    vozLoaded = true;

                    if (!window.$) {
                        vozLoaded = false;
                        vozTabContent.innerHTML = '<div class="alert alert-danger">Nedostaje jQuery za učitavanje taba.</div>';
                        return;
                    }

                    $('#vozTabContent').load('/Admin/UcitajSveVozove?ts=' + Date.now(), function (_, status) {
                        if (status === 'error') {
                            vozLoaded = false;
                            vozTabContent.innerHTML = '<div class="alert alert-danger">Greška pri učitavanju vozova i tipova.</div>';
                        }
                    });
                };

                vozTabBtn.addEventListener('shown.bs.tab', loadVozTab);

                if (vozTabBtn.classList.contains('active')) {
                    loadVozTab();
                }
            }

            const linijeTabBtn = document.querySelector('[data-bs-target="#tab-linije"]');
            const linijeTabContent = document.querySelector('#linijeStaniceTabContent');
            if (linijeTabBtn && linijeTabContent) {
                let linijeLoaded = false;

                const loadLinijeTab = (force = false, region = '') => {
                    const trimmedRegion = (region || '').trim();
                    if (linijeLoaded && !force && !trimmedRegion) return;
                    linijeLoaded = true;

                    if (!window.$) {
                        linijeLoaded = false;
                        linijeTabContent.innerHTML = '<div class="alert alert-danger">Nedostaje jQuery za učitavanje taba.</div>';
                        return;
                    }

                    const params = new URLSearchParams();
                    params.set('ts', Date.now().toString());
                    if (trimmedRegion) {
                        params.set('region', trimmedRegion);
                    }

                    $('#linijeStaniceTabContent').load('/Admin/UcitajLinijeStanice?' + params.toString(), function (_, status) {
                        if (status === 'error') {
                            if (!force && !trimmedRegion) {
                                linijeLoaded = false;
                            }
                            linijeTabContent.innerHTML = '<div class="alert alert-danger">Greška pri učitavanju linija i stanica.</div>';
                        }
                    });
                };

                window.reloadLinijeStaniceTab = (region = '') => loadLinijeTab(true, region);
                linijeTabBtn.addEventListener('shown.bs.tab', () => loadLinijeTab());

                if (linijeTabBtn.classList.contains('active')) {
                    loadLinijeTab();
                }
            }
        });

        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('.js-edit-toggle');
            if (!btn) return;

            const row = btn.closest('tr');
            if (!row) return;

            const isEditing = row.dataset.editing === '1';
            const role = row.dataset.role;
            const isUserRow = role === 'Administrator' || role === 'Kondukter';
            const isVozRow = role === 'Voz';
            const isTipVozaRow = role === 'TipVoza';
            const isLinijaRow = role === 'Linija';
            const isStanicaRow = role === 'Stanica';

            const showNotice = (message, ok) => {
                const notice = document.querySelector('#topNotice');
                if (!notice) return;
                notice.textContent = message;
                notice.classList.remove('d-none', 'alert-success', 'alert-danger');
                notice.classList.add(ok ? 'alert-success' : 'alert-danger');
            };

            const enterEditMode = () => {
                row.dataset.editing = '1';
                row.querySelectorAll('.cell-view').forEach(el => el.classList.add('d-none'));
                row.querySelectorAll('.cell-edit').forEach(el => {
                    const cell = el.closest('td');
                    const view = cell ? cell.querySelector('.cell-view') : null;
                    if (view) {
                        if (el.type === 'date') {
                            const raw = el.getAttribute('data-raw');
                            el.value = raw ? raw : view.textContent.trim();
                        } else if (el.tagName.toLowerCase() === 'select') {
                            const raw = el.getAttribute('data-raw');
                            if (raw) {
                                el.value = raw;
                            } else if (!view.classList.contains('badge-aktivan') && !view.classList.contains('badge-neaktivan')) {
                                const viewText = view.textContent.trim().toLowerCase();
                                const matched = Array.from(el.options).find(opt => (opt.textContent || '').trim().toLowerCase() === viewText);
                                if (matched) {
                                    el.value = matched.value;
                                }
                            } else {
                                el.value = view.textContent.trim();
                            }
                        } else {
                            el.value = view.textContent.trim();
                        }
                    }
                    el.classList.remove('d-none');
                });
                btn.textContent = 'Sačuvaj';
                btn.classList.remove('btn-sz-outline');
                btn.classList.add('btn-sz-primary');
            };

            const applyEdits = () => {
                row.querySelectorAll('.cell-edit').forEach(el => {
                    const cell = el.closest('td');
                    const view = cell ? cell.querySelector('.cell-view') : null;
                    if (view) {
                        const newValue = el.value;
                        if (el.type === 'date') {
                            if (newValue && newValue.includes('-')) {
                                const parts = newValue.split('-');
                                view.textContent = `${parts[2]}.${parts[1]}.${parts[0]}.`;
                            } else {
                                view.textContent = '';
                            }
                            el.setAttribute('data-raw', newValue);
                        } else if (el.tagName.toLowerCase() === 'select') {
                            const selectedOption = el.options[el.selectedIndex];
                            const selectedText = selectedOption ? (selectedOption.textContent || '') : newValue;
                            const selectedValue = selectedOption ? selectedOption.value : newValue;
                            el.setAttribute('data-raw', selectedValue);
                            view.textContent = selectedText;

                            if (view.classList.contains('badge-aktivan') || view.classList.contains('badge-neaktivan')) {
                                const yes = selectedText.trim().toLowerCase().startsWith('d');
                                if (yes) {
                                    view.classList.add('badge-aktivan');
                                    view.classList.remove('badge-neaktivan');
                                } else {
                                    view.classList.add('badge-neaktivan');
                                    view.classList.remove('badge-aktivan');
                                }
                            }
                        } else {
                            view.textContent = newValue;
                        }
                    }
                    el.classList.add('d-none');
                });
                row.querySelectorAll('.cell-view').forEach(el => el.classList.remove('d-none'));
                row.dataset.editing = '0';
                btn.textContent = 'Izmeni';
                btn.classList.add('btn-sz-outline');
                btn.classList.remove('btn-sz-primary');
                btn.disabled = false;
            };

            if (!isEditing) {
                enterEditMode();
                return;
            }

            if (!isUserRow && !isVozRow && !isTipVozaRow && !isLinijaRow && !isStanicaRow) {
                applyEdits();
                return;
            }

            const id = row.dataset.id;
            if (!id || (id === '-' && (isVozRow || isTipVozaRow || isLinijaRow || isStanicaRow))) {
                applyEdits();
                showNotice('Lokalna izmena (red još nije snimljen na serveru).', true);
                return;
            }

            if (!id) {
                showNotice('Nedostaje ID za čuvanje.', false);
                return;
            }

            const url = role === 'Administrator'
                ? '/Admin/IzmeniAdministratora'
                : role === 'Kondukter'
                    ? '/Admin/IzmeniKonduktera'
                    : role === 'Voz'
                        ? '/Admin/IzmeniVoz'
                        : role === 'TipVoza'
                            ? '/Admin/IzmeniTipVoza'
                            : role === 'Linija'
                                ? '/Admin/IzmeniLiniju'
                                : role === 'Stanica'
                                    ? '/Admin/IzmeniStanicu'
                                    : null;

            if (!url) {
                applyEdits();
                showNotice('Nepoznat tip reda za čuvanje.', false);
                return;
            }

            const form = new FormData();
            form.append('id', id);
            row.querySelectorAll('.cell-edit').forEach(el => {
                if (el.name) {
                    if (isVozRow && el.name === 'aktivan') {
                        const boolValue = el.value.trim().toLowerCase().startsWith('d') ? 'true' : 'false';
                        form.append(el.name, boolValue);
                    } else {
                        form.append(el.name, el.value);
                    }
                }
            });

            btn.disabled = true;
            const originalText = btn.textContent;
            btn.textContent = 'Čuvam...';

            try {
                const res = await fetch(url, {
                    method: 'PUT',
                    body: form
                });
                const text = await res.text();
                if (!res.ok) {
                    showNotice(text || 'Greška pri čuvanju.', false);
                    btn.disabled = false;
                    btn.textContent = originalText;
                    return;
                }
                showNotice(text || 'Uspešno sačuvano.', true);
                applyEdits();
            } catch (err) {
                showNotice('Greška u komunikaciji sa serverom.', false);
                btn.disabled = false;
                btn.textContent = originalText;
            }
        });

        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('.js-delete-user');
            if (!btn) return;

            const row = btn.closest('tr');
            if (!row) return;

            const role = row.dataset.role;
            if (role !== 'Administrator' && role !== 'Kondukter') return;

            const id = row.dataset.id;
            const showNotice = (message, ok) => {
                const notice = document.querySelector('#topNotice');
                if (!notice) return;
                notice.textContent = message;
                notice.classList.remove('d-none', 'alert-success', 'alert-danger');
                notice.classList.add(ok ? 'alert-success' : 'alert-danger');
            };

            if (!id) {
                showNotice('Nedostaje ID za brisanje.', false);
                return;
            }

            const potvrda = confirm('Da li ste sigurni da želite da obrišete ovog korisnika?');
            if (!potvrda) return;

            const url = role === 'Administrator'
                ? '/Admin/UkloniAdministratora'
                : '/Admin/UkloniKonduktera';

            btn.disabled = true;
            const originalText = btn.textContent;
            btn.textContent = 'Brišem...';

            try {
                const res = await fetch(url + '?id=' + encodeURIComponent(id), {
                    method: 'DELETE'
                });
                const text = await res.text();
                if (!res.ok) {
                    showNotice(text || 'Greška pri čuvanju.', false);
                    btn.disabled = false;
                    btn.textContent = originalText;
                    return;
                }
                showNotice(text || 'Uspešno obrisano.', true);
                if (window.$ && $('#korisniciTabContent').length) {
                    $('#korisniciTabContent').load('/Admin/UcitajKorisnike?ts=' + Date.now());
                }
            } catch (err) {
                showNotice('Greška u komunikaciji sa serverom.', false);
                btn.disabled = false;
                btn.textContent = originalText;
            }
        });

        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('.js-delete-local');
            if (!btn) return;

            const row = btn.closest('tr');
            if (!row) return;

            const tbody = row.closest('tbody');
            const role = row.dataset.role;
            const id = row.dataset.id;
            const isVozRow = role === 'Voz';
            const isTipVozaRow = role === 'TipVoza';
            const isLinijaRow = role === 'Linija';
            const isStanicaRow = role === 'Stanica';
            const shouldDeleteOnServer = (isVozRow || isTipVozaRow || isLinijaRow || isStanicaRow) && id && id !== '-';

            const notice = document.querySelector('#topNotice');
            const showNotice = (message, ok) => {
                if (!notice) return;
                notice.textContent = message;
                notice.classList.remove('d-none', 'alert-success', 'alert-danger');
                notice.classList.add(ok ? 'alert-success' : 'alert-danger');
            };

            const applyLocalDelete = () => {
                row.remove();
                if (tbody && !tbody.querySelector('tr')) {
                    const emptyRow = document.createElement('tr');
                    if (tbody.id === 'vozoviTableBody') {
                        emptyRow.className = 'js-voz-empty';
                        emptyRow.innerHTML = '<td class="text-muted" colspan="6">Nema vozova.</td>';
                    } else if (tbody.id === 'tipoviTableBody') {
                        emptyRow.className = 'js-tip-empty';
                        emptyRow.innerHTML = '<td class="text-muted" colspan="4">Nema tipova vozova.</td>';
                    } else if (tbody.id === 'linijeTableBody') {
                        emptyRow.className = 'js-linija-empty';
                        emptyRow.innerHTML = '<td class="text-muted" colspan="5">Nema linija.</td>';
                    } else if (tbody.id === 'staniceTableBody') {
                        emptyRow.className = 'js-stanica-empty';
                        emptyRow.innerHTML = '<td class="text-muted" colspan="4">Nema stanica.</td>';
                    }
                    tbody.appendChild(emptyRow);
                }
            };

            const potvrda = confirm('Da li ste sigurni da želite da obrišete ovu stavku?');
            if (!potvrda) return;

            if (!shouldDeleteOnServer) {
                applyLocalDelete();
                showNotice('Stavka je obrisana lokalno (frontend).', true);
                return;
            }

            const url = isVozRow
                ? '/Admin/UkloniVoz'
                : isTipVozaRow
                    ? '/Admin/UkloniTipVoza'
                    : isLinijaRow
                        ? '/Admin/UkloniLiniju'
                        : '/Admin/UkloniStanicu';
            const originalText = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Brišem...';

            try {
                const res = await fetch(url + '?id=' + encodeURIComponent(id), {
                    method: 'DELETE'
                });
                const text = await res.text();
                if (!res.ok) {
                    showNotice(text || 'Greška pri brisanju.', false);
                    btn.disabled = false;
                    btn.textContent = originalText;
                    return;
                }

                if (isTipVozaRow) {
                    const tipName = row.querySelector('td:nth-child(2) .cell-view')?.textContent?.trim();
                    const tipSelect = document.querySelector('#vozTipSelect');
                    if (tipSelect && tipName) {
                        const optionToRemove = Array.from(tipSelect.options)
                            .find(opt => opt.textContent.trim().toLowerCase() === tipName.toLowerCase());
                        if (optionToRemove) {
                            optionToRemove.remove();
                        }
                        tipSelect.disabled = tipSelect.options.length <= 1;
                        const vozBtn = document.querySelector('#dodajVozBtn');
                        if (vozBtn) {
                            vozBtn.disabled = tipSelect.disabled;
                        }
                    }
                }

                applyLocalDelete();
                showNotice(text || 'Uspešno obrisano.', true);
            } catch (err) {
                showNotice('Greška u komunikaciji sa serverom.', false);
                btn.disabled = false;
                btn.textContent = originalText;
            }
        });

        document.addEventListener('submit', async (e) => {
            const form = e.target;
            if (!(form instanceof HTMLFormElement)) return;

            const isDodajVoz = form.id === 'dodajVozForm';
            const isDodajTip = form.id === 'dodajTipVozaForm';
            const isDodajLinija = form.id === 'dodajLinijaForm';
            const isDodajStanica = form.id === 'dodajStanicaForm';
            if (!isDodajVoz && !isDodajTip && !isDodajLinija && !isDodajStanica) return;

            e.preventDefault();

            const notice = document.querySelector('#topNotice');
            const showNotice = (message, ok) => {
                if (!notice) return;
                notice.textContent = message;
                notice.classList.remove('d-none', 'alert-success', 'alert-danger');
                notice.classList.add(ok ? 'alert-success' : 'alert-danger');
            };

            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn ? submitBtn.textContent : '';
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Čuvam...';
            }

            const createEditableCell = (value, inputName, strong, cssClass, editValue = null) => {
                const cell = document.createElement('td');
                if (cssClass) {
                    cell.className = cssClass;
                }

                const viewEl = document.createElement(strong ? 'strong' : 'span');
                viewEl.className = 'cell-view';
                viewEl.textContent = value;

                const editEl = document.createElement('input');
                editEl.name = inputName;
                editEl.className = 'form-control form-control-sm cell-edit d-none';
                editEl.value = editValue ?? value;

                cell.appendChild(viewEl);
                cell.appendChild(editEl);
                return cell;
            };

            const createActionsCell = () => {
                const cell = document.createElement('td');
                cell.className = 'cell-actions';

                const editBtn = document.createElement('button');
                editBtn.className = 'btn btn-sz-outline js-edit-toggle';
                editBtn.textContent = 'Izmeni';

                const deleteBtn = document.createElement('button');
                deleteBtn.className = 'btn btn-sz-danger ms-2 js-delete-local';
                deleteBtn.textContent = 'Ukloni';

                cell.appendChild(editBtn);
                cell.appendChild(deleteBtn);
                return cell;
            };

            try {
                const res = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form)
                });
                const text = await res.text();

                if (!res.ok) {
                    showNotice(text || 'Greška pri čuvanju.', false);
                    return;
                }

                if (isDodajTip) {
                    if (window.$ && $('#vozTabContent').length) {
                        $('#vozTabContent').load('/Admin/UcitajSveVozove?ts=' + Date.now());
                    }
                }

                if (isDodajVoz) {
                    if (window.$ && $('#vozTabContent').length) {
                        $('#vozTabContent').load('/Admin/UcitajSveVozove?ts=' + Date.now());
                    }
                }

                if (isDodajLinija || isDodajStanica) {
                    if (typeof window.reloadLinijeStaniceTab === 'function') {
                        window.reloadLinijeStaniceTab();
                    } else if (window.$ && $('#linijeStaniceTabContent').length) {
                        $('#linijeStaniceTabContent').load('/Admin/UcitajLinijeStanice?ts=' + Date.now());
                    }
                }

                showNotice(text || 'Uspešno sačuvano.', true);
                form.reset();
            } catch (err) {
                showNotice('Greška u komunikaciji sa serverom.', false);
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                }
            }
        });

        document.addEventListener('submit', (e) => {
            const form = e.target;
            if (!(form instanceof HTMLFormElement) || form.id !== 'filtrirajStaniceForm') return;

            e.preventDefault();
            const region = ((new FormData(form).get('region') || '').toString()).trim();
            if (typeof window.reloadLinijeStaniceTab === 'function') {
                window.reloadLinijeStaniceTab(region);
            } else if (window.$ && $('#linijeStaniceTabContent').length) {
                const query = new URLSearchParams({ ts: Date.now().toString() });
                if (region) {
                    query.set('region', region);
                }
                $('#linijeStaniceTabContent').load('/Admin/UcitajLinijeStanice?' + query.toString());
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            const tipSelect = document.querySelector('#vozTipSelect');
            const vozBtn = document.querySelector('#dodajVozBtn');
            if (!tipSelect || !vozBtn) return;

            vozBtn.disabled = tipSelect.options.length <= 1;
        });

        document.addEventListener('DOMContentLoaded', () => {
            const form = document.querySelector('#promocijaForm');
            const notice = document.querySelector('#topNotice');
            if (!form || !notice) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                notice.classList.add('d-none');
                notice.classList.remove('alert-success', 'alert-danger');

                try {
                    const res = await fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form)
                    });
                    const text = await res.text();
                    notice.textContent = text || (res.ok ? 'Uspešno sačuvano.' : 'Greška pri čuvanju.');
                    notice.classList.add(res.ok ? 'alert-success' : 'alert-danger');
                    notice.classList.remove('d-none');

                    if (res.ok && window.$ && $('#korisniciTabContent').length) {
                        $('#korisniciTabContent').load('/Admin/UcitajKorisnike?ts=' + Date.now());
                    }
                } catch (err) {
                    notice.textContent = 'Greška u komunikaciji sa serverom.';
                    notice.classList.add('alert-danger');
                    notice.classList.remove('d-none');
                }
            });
        });
    </script>
}









