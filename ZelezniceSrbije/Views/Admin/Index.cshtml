@{
    ViewData["Title"] = "Admin Panel";
}
<style>
        :root {
            --sz-red: #CC0000;
            --sz-blue: #003B8E;
        }

        body {
            background-color: #f4f6f9;
        }

        .sz-hero {
            background: var(--sz-blue);
            padding: 3rem 2rem 2.5rem;
            position: relative;
            overflow: hidden;
            margin-bottom: 2rem;
        }
        .sz-hero::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0; height: 6px;
            background: repeating-linear-gradient(
                90deg,
                var(--sz-red) 0px, var(--sz-red) 40px,
                #fff 40px, #fff 44px
            );
        }
        .sz-hero h1 {
            font-family: 'Oswald', sans-serif;
            font-size: 42px;
            color: white;
            font-weight: 600;
            margin: 0 0 8px;
        }
        .sz-hero h1 span { color: var(--sz-red); }
        .sz-hero p {
            color: rgba(255,255,255,0.8);
            font-size: 16px;
            margin: 0;
        }

        .nav-tabs .nav-link {
            font-family: 'Oswald', sans-serif;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6c757d;
            border: none;
            border-bottom: 3px solid transparent;
            padding: 10px 20px;
            background: none;
        }
        .nav-tabs .nav-link:hover { color: var(--sz-blue); border-bottom-color: var(--sz-blue); }
        .nav-tabs .nav-link.active {
            color: var(--sz-blue);
            border-bottom: 3px solid var(--sz-blue);
            font-weight: 600;
            background: none;
        }
        .nav-tabs { border-bottom: 2px solid #dee2e6; margin-bottom: 1.5rem; }
.card { border: none; border-radius: 4px; }
        .card-header-label {
            font-family: 'Oswald', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-size: 13px;
            color: var(--sz-blue);
        }

        .sz-table thead th {
            font-family: 'Oswald', sans-serif;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #6c757d;
            border-bottom: 2px solid var(--sz-blue);
            padding: 10px 12px;
        }
        .sz-table tbody td {
            padding: 14px 12px;
            font-size: 0.95rem;
            vertical-align: middle;
            border-color: #f0f0f0;
        }
        .sz-table tbody tr:last-child td { border-bottom: none; }
        .sz-table thead th:last-child { text-align: center; }
        .sz-table th:last-child,
        .sz-table td:last-child { width: 160px; }
        .linija-cena-col { width: 105px; }

        .sz-badge {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 3px 9px;
            border-radius: 2px;
        }
        .badge-admin     { background: #e6f0ff; color: var(--sz-blue); }
        .badge-kondukter { background: #ffe6e6; color: var(--sz-red);  }
        .badge-putnik    { background: #f0f0f0; color: #6c757d;        }
        .badge-aktivan   { background: #e8f5e9; color: #198754;        }
        .badge-neaktivan { background: #fdecea; color: #b71c1c;        }

        .btn-sz-primary {
            background: var(--sz-red); color: white; border: none;
            font-weight: 600; font-size: 0.875rem; border-radius: 2px; padding: 8px 18px;
        }
        .btn-sz-primary:hover { background: #aa0000; color: white; }

        .btn-sz-outline {
            border: 1px solid var(--sz-blue); color: var(--sz-blue);
            background: transparent; font-size: 0.8rem; font-weight: 600;
            border-radius: 2px; padding: 4px 12px;
        }
        .btn-sz-outline:hover { background: var(--sz-blue); color: white; }

        .sz-route {
            display: flex; flex-wrap: wrap; gap: 4px;
            list-style: none; padding: 0; margin: 0;
            font-size: 0.85rem; color: #444;
        }
        .sz-route li + li::before {
            content: '›'; color: var(--sz-red); margin-right: 4px; font-weight: 700;
        }
        .sz-route .vreme {
            font-size: 0.72rem; color: #aaa; display: block;
        }

        .field-label {
            font-size: 0.7rem; text-transform: uppercase;
            letter-spacing: 0.5px; color: #aaa; display: block; margin-bottom: 1px;
        }

        .sz-subtle {
            font-size: 0.7rem;
            letter-spacing: 0.6px;
            text-transform: uppercase;
            color: #9aa4b2;
        }
        .sz-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #7a8796;
            margin-bottom: 0.35rem;
        }
        .sz-input {
            border-radius: 2px;
            border-color: #dee2e6;
            font-size: 0.95rem;
        }
        .sz-input:focus {
            border-color: var(--sz-blue);
            box-shadow: 0 0 0 0.15rem rgba(0, 59, 142, 0.15);
        }
        .sz-divider {
            height: 1px;
            background: #eef1f4;
            margin: 1.25rem 0;
        }
        .sz-help {
            font-size: 0.85rem;
            color: #6c757d;
        }
        .sz-note {
            margin: 0;
            font-size: 0.9rem;
            color: #4f5b6b;
        }
        .btn-sz-danger {
            border: 1px solid #b71c1c;
            color: #b71c1c;
            background: #fff5f5;
            font-size: 0.8rem;
            font-weight: 600;
            border-radius: 2px;
            padding: 4px 12px;
        }
        .btn-sz-danger:hover { background: #b71c1c; color: white; }
        .cell-actions {
            white-space: nowrap;
            display: flex;
            justify-content: center;
            gap: 8px;
            align-items: center;
        }
        .btn-match-input {
            height: 38px;
            padding-top: 0;
            padding-bottom: 0;
        }
    </style>
<div class="sz-hero">
    <div class="container">
        <h1>Admin <span>Panel</span></h1>
        <p>Centralni sistem za upravljanje infrastrukturom Železnica Srbije</p>
    </div>
</div>

<div class="container mb-5">
    <div id="topNotice" class="alert text-center d-none" role="alert"></div>

    <ul class="nav nav-tabs" id="adminTabs">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-korisnici">Korisnici</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-vozovi">Vozovi i Tipovi</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-linije">Linije i Stanice</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-rasporedi">Rasporedi</button>
        </li>
    </ul>

    <div class="tab-content">


        <div class="tab-pane fade show active" id="tab-korisnici">
            <div class="row g-4">
                <div class="col-lg-5">
                    <div class="card shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="card-header-label">Promocija korisnika</span>
                                <span class="sz-subtle">Pretraga po emailu</span>
                            </div>
                            <form id="promocijaForm" asp-controller="Admin" asp-action="PromovisiUlogu" method="post">
                                <div class="mb-3">
                                    <label class="form-label sz-label">Email korisnika</label>
                                    <input type="email" name="email" class="form-control sz-input" placeholder="ime.prezime@email.com">
                                </div>

                                <div class="row g-3 align-items-end">
                                    <div class="col-md-6">
                                        <label class="form-label sz-label">Uloga</label>
                                        <select name="uloga" class="form-select sz-input">
                                            <option value="Administrator" selected>Administrator</option>
                                            <option value="Kondukter">Kondukter</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <button type="submit" class="btn btn-sz-primary w-100">Promoviši</button>
                                    </div>
                                </div>

                                <div class="sz-divider"></div>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label sz-label">Datum zaposlenja (admin)</label>
                                        <input type="date" name="datum" class="form-control sz-input">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label sz-label">Broj legitimacije (kondukter)</label>
                                        <input type="text" name="broj_legitimacije" class="form-control sz-input" placeholder="#84729">
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>

                </div>

                <div class="col-lg-7">
                    <div id="korisniciTabContent">
                        <div class="card shadow-sm mb-4">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="card-header-label">Administratori</span>
                                </div>
                                <table class="table sz-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Id</th>
                                            <th>Ime</th>
                                            <th>Prezime</th>
                                            <th>Email</th>
                                            <th>Datum zaposlenja</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="text-muted" colspan="6">Učitavanje...</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="card shadow-sm">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="card-header-label">Kondukteri</span>
                                </div>
                                <table class="table sz-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Id</th>
                                            <th>Ime</th>
                                            <th>Prezime</th>
                                            <th>Email</th>
                                            <th>Broj legitimacije</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="text-muted" colspan="6">Učitavanje...</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-vozovi">
            <div id="vozTabContent">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <span class="text-muted">Učitavanje...</span>
                    </div>
                </div>
            </div>
        </div>


        <div class="tab-pane fade" id="tab-linije">
            <div id="linijeStaniceTabContent">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <span class="text-muted">Učitavanje...</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-rasporedi">
