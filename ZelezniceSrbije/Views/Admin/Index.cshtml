                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Rasporedi Vožnje</span>
                        <button class="btn btn-sz-primary">+ Novi Raspored</button>
                    </div>
                    <table class="table sz-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Linija</th>
                                <th>Voz</th>
                                <th>Polazak s polazišta</th>
