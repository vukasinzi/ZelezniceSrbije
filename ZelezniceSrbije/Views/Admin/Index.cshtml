                    </div>
                    <table class="table sz-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Ime i Prezime</th>
                                <th>Email</th>
                                <th>Uloga</th>
                                <th>Specifično polje</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                     
                            <tr>
                                <td class="text-muted">1</td>
                                <td><strong>Marko Marković</strong></td>
                                <td class="text-muted">marko@zeleznice.rs</td>
                                <td><span class="sz-badge badge-admin">Administrator</span></td>
                                <td>
                                    <span class="field-label">Datum zaposlenja</span>
                                    12.05.2023.
                                </td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                   
                            <tr>
                                <td class="text-muted">2</td>
                                <td><strong>Jovan Jovanović</strong></td>
                                <td class="text-muted">jovan@zeleznice.rs</td>
                                <td><span class="sz-badge badge-kondukter">Kondukter</span></td>
                                <td>
                                    <span class="field-label">Broj legitimacije</span>
                                    #84729
                                </td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                  
                            <tr>
                                <td class="text-muted">3</td>
                                <td><strong>Ana Anić</strong></td>
                                <td class="text-muted">ana@putnik.rs</td>
                                <td><span class="sz-badge badge-putnik">Putnik</span></td>
                                <td>
                                    <span class="field-label">Broj telefona</span>
                                    0641234567
                                </td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-vozovi">


            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Vozovi</span>
                        <button class="btn btn-sz-primary">+ Dodaj Voz</button>
                    </div>
                    <table class="table sz-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Naziv</th>
                                <th>Serijski broj</th>
                                <th>Tip voza</th>
                                <th>Aktivan</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">1</td>
                                <td><strong>Soko</strong></td>
                                <td class="text-muted">SOK-410-001</td>
                                <td>InterCity</td>
                                <td><span class="sz-badge badge-aktivan">Da</span></td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                            <tr>
                                <td class="text-muted">2</td>
                                <td><strong>Regio Express</strong></td>
                                <td class="text-muted">RE-210-007</td>
                                <td>Regio</td>
                                <td><span class="sz-badge badge-aktivan">Da</span></td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                            <tr>
                                <td class="text-muted">3</td>
                                <td><strong>Stari Putnik</strong></td>
                                <td class="text-muted">SP-100-002</td>
                                <td>Lokalni</td>
                                <td><span class="sz-badge badge-neaktivan">Ne</span></td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>


            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Tipovi Voza</span>
                        <button class="btn btn-sz-primary">+ Dodaj Tip</button>
                    </div>
                    <table class="table sz-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Naziv</th>
                                <th>Opis</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">1</td>
                                <td><strong>InterCity</strong></td>
                                <td class="text-muted">Brzi međugradski vozovi</td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                            <tr>
                                <td class="text-muted">2</td>
                                <td><strong>Regio</strong></td>
                                <td class="text-muted">Regionalni vozovi</td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                            <tr>
                                <td class="text-muted">3</td>
                                <td><strong>Lokalni</strong></td>
                                <td class="text-muted">Lokalni putnički saobraćaj</td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>


        <div class="tab-pane fade" id="tab-linije">

 
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Linije</span>
                        <button class="btn btn-sz-primary">+ Nova Linija</button>
                    </div>
                    <table class="table sz-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Naziv</th>
                                <th>Cena po minutu</th>
                                <th>Ruta (redosled · min od polaska)</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">1</td>
                                <td><strong>Beograd – Novi Sad</strong></td>
                                <td>15 RSD</td>
                                <td>
                                    <ul class="sz-route">
                                        <li>Beograd Centar<span class="vreme">+0 min</span></li>
                                        <li>Novi Beograd<span class="vreme">+8 min</span></li>
                                        <li>Zemun<span class="vreme">+15 min</span></li>
                                        <li>Stara Pazova<span class="vreme">+30 min</span></li>
                                        <li>Novi Sad<span class="vreme">+45 min</span></li>
                                    </ul>
                                </td>
                                <td><button class="btn btn-sz-outline">Uredi Rutu</button></td>
                            </tr>
                            <tr>
                                <td class="text-muted">2</td>
                                <td><strong>Novi Sad – Subotica</strong></td>
                                <td>12 RSD</td>
                                <td>
                                    <ul class="sz-route">
                                        <li>Novi Sad<span class="vreme">+0 min</span></li>
                                        <li>Vrbas<span class="vreme">+20 min</span></li>
                                        <li>Bačka Topola<span class="vreme">+40 min</span></li>
                                        <li>Subotica<span class="vreme">+65 min</span></li>
                                    </ul>
                                </td>
                                <td><button class="btn btn-sz-outline">Uredi Rutu</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Stanice</span>
                        <button class="btn btn-sz-primary">+ Dodaj Stanicu</button>
                    </div>
                    <table class="table sz-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Naziv</th>
                                <th>Opština</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">1</td>
                                <td><strong>Beograd Centar</strong></td>
                                <td class="text-muted">Beograd</td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
                            </tr>
                            <tr>
                                <td class="text-muted">2</td>
                                <td><strong>Novi Beograd</strong></td>
                                <td class="text-muted">Beograd</td>
                                <td><button class="btn btn-sz-outline">Izmeni</button></td>
