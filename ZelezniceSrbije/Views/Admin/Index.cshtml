                                    <button class="btn btn-sz-danger ms-2">Ukloni</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>


            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="card-header-label">Tipovi Voza</span>
