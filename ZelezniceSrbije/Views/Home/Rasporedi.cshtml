@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model List<RasporedDTO>

@{
  DateTime? datumPolaska = ViewData["Datum"] is DateTime d ? d : null;
  var polaziste = ViewData["Polaziste"] as string;
  var odrediste = ViewData["Odrediste"] as string;
  var korisnik = User?.Identity?.IsAuthenticated == true ? User.Identity?.Name : null;

  var hasKupovinaContext =
    datumPolaska.HasValue &&
    !string.IsNullOrWhiteSpace(polaziste) &&
    !string.IsNullOrWhiteSpace(odrediste) &&
    !string.IsNullOrWhiteSpace(korisnik);

  var datumPolaskaIso = datumPolaska?.ToString("yyyy-MM-dd");
  var datumPolaskaDisplay = datumPolaska?.ToString("dd.MM.yyyy");
  var kupiActionUrl = Url.Action("Kupi", "Karta") ?? "/Karta/Kupi";
  var requestVerificationToken = Antiforgery.GetAndStoreTokens(Context).RequestToken ?? string.Empty;
}

<style>
  .rr-card { border-radius: 14px; overflow: hidden; border: 1px solid rgba(0,0,0,.08); }
  .rr-head { background: var(--sz-blue, #003B8E); color: #fff; }
  .rr-chip { font-size: 12px; border-radius: 999px; padding: 4px 10px; background: #f1f3f5; color: #333; }
  .rr-buy-btn { min-width: 120px; }
  .rr-time { font-weight: 700; font-size: 18px; letter-spacing: .5px; font-variant-numeric: tabular-nums; }
  .rr-sub { font-size: 12px; color: #6c757d; }
  .rr-station { font-size: 11px; color: #6c757d; }
  .rr-row { border-top: 1px solid rgba(0,0,0,.06); }
  .rr-row-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
  }
  .rr-col-line { min-width: 0; }
  .rr-col-times { justify-self: center; }
  .rr-times-grid {
    display: grid;
    grid-template-columns: 120px 120px;
    gap: 16px;
    text-align: center;
  }
  .rr-col-time { text-align: center; }
  .rr-col-chip { justify-self: end; text-align: right; }

  @@media (max-width: 768px) {
    .rr-row-grid {
      grid-template-columns: 1fr;
    }
    .rr-col-line {
      grid-column: 1 / -1;
    }
    .rr-col-times {
      grid-column: 1 / -1;
      justify-self: center;
    }
    .rr-times-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .rr-col-chip {
      grid-column: 1 / -1;
      justify-self: start;
      text-align: left;
    }
    .rr-col-chip .d-flex {
      align-items: flex-start !important;
    }
  }
</style>

<div class="card rr-card shadow-sm mt-4">
  <div class="card-header rr-head">
    <div class="d-flex align-items-center justify-content-between">
      <div class="fw-bold">Rezultati pretrage</div>
      @if (!string.IsNullOrWhiteSpace(datumPolaskaDisplay))
      {
        <div class="small opacity-75">@datumPolaskaDisplay</div>
      }
    </div>
  </div>

  @if (Model == null || Model.Count == 0)
  {
    <div class="card-body">
      <div class="text-muted">Nema dostupnih polazaka za izabrane stanice i datum.</div>
    </div>
  }
  else
  {
    if (!hasKupovinaContext)
    {
      <div class="alert alert-warning m-3 mb-0">
        Kupovina karte nije dostupna dok nisu prisutni svi validni podaci pretrage i ulogovan korisnik.
      </div>
    }

    <div class="list-group list-group-flush">
      @foreach (var r in Model)
      {
        var trajanje = (r.DolazakNaOdr - r.PolazakSaPol).ToString(@"hh\:mm");
        <div class="list-group-item rr-row">
          <div class="rr-row-grid">
            <div class="rr-col-line d-flex flex-column">
              <div class="fw-bold">@r.Linija</div>
              <div class="rr-sub">@r.TipVoza</div>
            </div>

            <div class="rr-col-times">
              <div class="rr-times-grid">
                <div class="rr-col-time">
                  <div class="rr-time">@r.PolazakSaPol.ToString("HH:mm")</div>
                  @if (!string.IsNullOrWhiteSpace(polaziste))
                  {
                    <div class="rr-station">@polaziste</div>
                  }
                  <div class="rr-sub">Polazak</div>
                </div>

                <div class="rr-col-time">
                  <div class="rr-time">@r.DolazakNaOdr.ToString("HH:mm")</div>
                  @if (!string.IsNullOrWhiteSpace(odrediste))
                  {
                    <div class="rr-station">@odrediste</div>
                  }
                  <div class="rr-sub">Dolazak</div>
                </div>
              </div>
            </div>

            <div class="rr-col-chip">
              <div class="d-flex flex-column align-items-end gap-2">
                <span class="rr-chip">
                  Trajanje: @trajanje
                </span>
                @if (hasKupovinaContext)
                {
                  <button type="button"
                          class="btn btn-danger btn-sm rr-buy-btn js-kupi-kartu"
                          data-linija="@r.Linija"
                          data-tip-voza="@r.TipVoza"
                          data-polazak-vreme="@r.PolazakSaPol.ToString("HH:mm")"
                          data-dolazak-vreme="@r.DolazakNaOdr.ToString("HH:mm")"
                          data-polaziste="@polaziste"
                          data-odrediste="@odrediste"
                          data-trajanje="@trajanje"
                          data-datum-iso="@datumPolaskaIso"
                          data-datum-display="@datumPolaskaDisplay"
                          data-korisnik="@korisnik"
                          data-raspored-id="@r.Id">
                    Kupi kartu
                  </button>
                }
              </div>
            </div>
          </div>
        </div>
      }
    </div>
  }
</div>

<script>
  (() => {
    const kupiActionUrl = '@kupiActionUrl';
    const requestVerificationToken = '@requestVerificationToken';

    const readRequired = (value, label) => {
      const parsed = (value || '').trim();
      if (!parsed) {
        throw new Error(`Nedostaje obavezan podatak: ${label}.`);
      }
      return parsed;
    };

    const stanicaIdMap = {};
    document.querySelectorAll('#stanice option[data-id]').forEach((option) => {
      const naziv = (option.value || '').trim().toLowerCase();
      const id = (option.dataset.id || '').trim();
      if (naziv && id) {
        stanicaIdMap[naziv] = id;
      }
    });

    const resolveStanicaId = (naziv, label) => {
      const key = readRequired(naziv, label).toLowerCase();
      const id = readRequired(stanicaIdMap[key], `${label}_id`);
      if (!/^\d+$/.test(id)) {
        throw new Error(`Neispravan ${label}_id.`);
      }
      return id;
    };

    const buttons = document.querySelectorAll('.js-kupi-kartu');
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        try {
          const data = button.dataset;

          const korisnik = readRequired(data.korisnik, 'korisnik');
          const datumDisplay = readRequired(data.datumDisplay, 'datum polaska (display)');
          const polazakVreme = readRequired(data.polazakVreme, 'vreme polaska');
          const polaziste = readRequired(data.polaziste, 'polaziste');
          const odrediste = readRequired(data.odrediste, 'odrediste');
          const polazisteId = resolveStanicaId(polaziste, 'polaziste');
          const odredisteId = resolveStanicaId(odrediste, 'odrediste');
          const rasporedId = readRequired(data.rasporedId, 'raspored_id');
          if (!/^\d+$/.test(rasporedId)) {
            throw new Error('Neispravan raspored_id.');
          }

          const poruka =
            `Da li ste sigurni da zelite kupiti kartu za korisnika ${korisnik}, ` +
            `dana ${datumDisplay}, u ${polazakVreme}, od ${polaziste} do ${odrediste}?`;

          if (!window.confirm(poruka)) {
            return;
          }

          const postForm = document.createElement('form');
          postForm.method = 'post';
          postForm.action = kupiActionUrl;

          const fields = {
            raspored_id: rasporedId,
            polaziste_id: polazisteId,
            odrediste_id: odredisteId
          };

          Object.entries(fields).forEach(([name, value]) => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = name;
            input.value = value;
            postForm.appendChild(input);
          });

          if (requestVerificationToken) {
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = requestVerificationToken;
            postForm.appendChild(tokenInput);
          }

          document.body.appendChild(postForm);
          postForm.submit();
        } catch (error) {
          window.alert(error instanceof Error ? error.message : 'Kupovina nije moguca.');
        }
      });
    });
  })();
</script>
