@model KartaDTO

@{
    ViewData["Title"] = $"Karta #{Model.karta_id}";
    var qrImageData = ViewData["QrImageData"] as string;
}

<style>
    .ticket-wrap {
        max-width: 900px;
        margin: 1.5rem auto;
    }

    .ticket-card {
        border: 1px solid #dbe4f0;
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
    }

    .ticket-head {
        background: #003B8E;
        color: #fff;
        padding: 16px 20px;
    }

    .ticket-body {
        padding: 20px;
    }

    .ticket-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 20px;
    }

    .ticket-meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px 16px;
    }

    .ticket-label {
        font-size: 12px;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .ticket-value {
        font-size: 16px;
        font-weight: 600;
    }

    .ticket-qr-box {
        border: 1px solid #e9ecef;
        border-radius: 10px;
        padding: 12px;
        text-align: center;
    }

    .ticket-qr-box img {
        max-width: 220px;
        width: 100%;
        height: auto;
    }

    .ticket-actions {
        margin-top: 16px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    @@media (max-width: 768px) {
        .ticket-grid {
            grid-template-columns: 1fr;
        }
    }

</style>

<div class="ticket-wrap">
    <div class="ticket-card shadow-sm">
        <div class="ticket-head d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-bold">Železnice Srbije - Elektronska karta</div>
                <div class="small opacity-75">ID karte: @Model.karta_id</div>
            </div>
            <div class="small">
                Status:
                <strong>@(Model.ocitana ? "Očitana" : "Neočitana")</strong>
            </div>
        </div>

        <div class="ticket-body">
            <div class="ticket-grid">
                <div class="ticket-meta-grid">
                    <div>
                        <div class="ticket-label">Putnik</div>
                        <div class="ticket-value">@Model.putnik</div>
                    </div>
                    <div>
                        <div class="ticket-label">Linija</div>
                        <div class="ticket-value">@Model.linija (@Model.tip_voza)</div>
                    </div>
                    <div>
                        <div class="ticket-label">Polazište</div>
                        <div class="ticket-value">@Model.polaziste</div>
                    </div>
                    <div>
                        <div class="ticket-label">Odredište</div>
                        <div class="ticket-value">@Model.odrediste</div>
                    </div>
                    <div>
                        <div class="ticket-label">Polazak</div>
                        <div class="ticket-value">@Model.vreme_polaska.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                    <div>
                        <div class="ticket-label">Dolazak</div>
                        <div class="ticket-value">@Model.vreme_dolaska.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                    <div>
                        <div class="ticket-label">Trajanje</div>
                        <div class="ticket-value">@Model.trajanje</div>
                    </div>
                    <div>
                        <div class="ticket-label">Cena</div>
                        <div class="ticket-value">@Model.cena.ToString("0.00") RSD</div>
                    </div>
                    @if (Model.datum_ocitavanja.HasValue)
                    {
                        <div>
                            <div class="ticket-label">Datum očitavanja</div>
                            <div class="ticket-value">@Model.datum_ocitavanja.Value.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                    }
                </div>

                <div class="ticket-qr-box">
                    <div class="ticket-label mb-2">QR kod karte</div>
                    @if (!string.IsNullOrWhiteSpace(qrImageData))
                    {
                        <img src="@qrImageData" alt="QR kod karte" />
                    }
                    else
                    {
                        <div class="text-muted small">QR nije dostupan.</div>
                    }
                </div>
            </div>

            <div class="ticket-actions">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Nazad na početnu</a>
            </div>
        </div>
    </div>
</div>
